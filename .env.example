# ── Google Sheets (Service Account) ──────────────────────────────────────────
# Create a Service Account in Google Cloud Console, enable Sheets API,
# share your sheet with the service account email, then paste credentials here.
GOOGLE_SERVICE_ACCOUNT_EMAIL=sync@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# The spreadsheet ID from the Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=your-sheet-id-here

# Tab name and column range (adjust the tab name to match your sheet)
SHEET_RANGE=Sheet1!A:Z

# ── Mailchimp ─────────────────────────────────────────────────────────────────
# Mailchimp → Account → Extras → API Keys
# The suffix after the dash (-us12) is your server prefix
MAILCHIMP_API_KEY=your-api-key-here-us12
MAILCHIMP_SERVER_PREFIX=us12

# Mailchimp → Audience → Settings → Audience name and defaults → Audience ID
MAILCHIMP_AUDIENCE_ID=your-audience-id-here

# ── Mailchimp Merge Tag Mapping ───────────────────────────────────────────────
# Open Mailchimp → Audience → Settings → Audience fields and *MERGE TAGS*
# Copy the tag name shown between *| and |* for each field below.
MC_TAG_FULLNAME=FLNAME
MC_TAG_MEMBERSHIP=MEMBERSHIP
MC_TAG_MEMBERSHIP_MOD=MODIFIER
MC_TAG_MEMBERID=HHYCMID

# ── Vercel KV (Upstash Redis) ─────────────────────────────────────────────────
# Vercel Dashboard → Storage → your KV store → ".env.local" tab
# Must be the REST API format (https://...), NOT a redis:// connection string
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token-here

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must match the WEBHOOK_SECRET value in your Google Apps Script
WEBHOOK_SECRET=your-32-char-hex-secret-here

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
